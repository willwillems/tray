---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const features = [
  { name: "Parts with categories, tags, and parameters", desc: "Organize your inventory the way you think about it" },
  { name: "Multi-location stock tracking", desc: "Know what you have, where it is, and when you're running low" },
  { name: "Suppliers and pricing", desc: "Track where to buy parts and compare prices" },
  { name: "Projects and BOMs", desc: "Define what you need to build, check stock, deduct on completion" },
  { name: "Purchase and build orders", desc: "Track orders and allocate stock for builds" },
  { name: "KiCad integration", desc: "Use your inventory as a KiCad symbol library" },
  { name: "Full audit log", desc: "Every change is logged and revertable with tray undo" },
  { name: "Parametric search", desc: "Find parts by specs like resistance>=10k" },
  { name: "Plugin system", desc: "Extend with scripts in any language" },
  { name: "Single binary, local SQLite", desc: "No servers, no Docker, no cloud dependency" },
];
---

<BaseLayout title="Tray -- CLI-first inventory management for makers">
  <main class="mx-auto max-w-2xl px-6">
    <!-- Hero -->
    <section class="pb-16 pt-24">
      <h1 class="text-3xl font-semibold tracking-tight">
        CLI-first inventory management for makers
      </h1>
      <p class="mt-4 text-base leading-relaxed text-muted" style="text-wrap: balance;">
        A single binary with a local SQLite database. No servers to configure,
        no Docker, no browser required. Every operation is a CLI command.
      </p>
      <div class="mt-8 flex gap-3">
        <a
          href={`${base}/docs`}
          class="inline-flex items-center rounded-full bg-fg px-5 py-2 text-sm font-medium text-bg transition-opacity hover:opacity-90"
        >
          Get Started
        </a>
        <a
          href="https://github.com/willwillems/tray"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-border px-5 py-2 text-sm font-medium text-fg transition-colors hover:border-muted"
        >
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="currentColor">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
          </svg>
          GitHub
        </a>
      </div>
    </section>

    <!-- Code Example -->
    <section class="pb-16">
      <pre class="overflow-x-auto rounded-lg border border-border bg-code-bg p-5 text-sm leading-relaxed"><code><span class="text-muted">$</span> tray add "NE555" --category "ICs/Timers" --stock 25 --location "Drawer 3"
<span class="text-muted">$</span> tray add "LM7805" --category "ICs/Voltage Regulators" --stock 10
<span class="text-muted">$</span> tray list --low
<span class="text-muted">$</span> tray search "555"
<span class="text-muted">$</span> tray buy "NE555"</code></pre>
    </section>

    <!-- Features -->
    <section class="pb-24">
      <h2 class="mb-6 text-xs font-medium uppercase tracking-widest text-muted">
        Features
      </h2>
      <ul class="space-y-3 text-sm">
        {features.map((f) => (
          <li>
            <span class="text-muted">-</span>{" "}
            <strong>{f.name}</strong>{" "}
            <span class="text-muted">{f.desc}</span>
          </li>
        ))}
      </ul>
    </section>
  </main>
</BaseLayout>
